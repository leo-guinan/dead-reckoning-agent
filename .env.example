# .env.example — Copy to .env and fill in
# Never commit .env to version control

# ── Model Provider (pick one) ────────────────────────────────────────────────
# OpenRouter (recommended — access to all models with one key)
OPENROUTER_API_KEY=

# OpenAI direct
OPENAI_API_KEY=

# Anthropic direct
ANTHROPIC_API_KEY=

# ── Model Selection ───────────────────────────────────────────────────────────
# Default model for most tasks
DEFAULT_MODEL=anthropic/claude-3-haiku

# Model for heartbeat checks (use cheapest viable)
HEARTBEAT_MODEL=openai/gpt-4.1-nano

# ── Email Sensor (AgentMail) ──────────────────────────────────────────────────
# Get key from console.agentmail.to
AGENTMAIL_API_KEY=
# Full inbox address e.g. myagent@agentmail.to
AGENTMAIL_INBOX=

# ── Webhook Sensor ────────────────────────────────────────────────────────────
WEBHOOK_PORT=3090
# Optional: HMAC secret for webhook signature verification
WEBHOOK_SECRET=

# ── Notifications (optional) ─────────────────────────────────────────────────
# Command to notify human on alert (e.g. "ntfy pub my-topic")
NOTIFY_CMD=
